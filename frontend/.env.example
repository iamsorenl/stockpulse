# Frontend environment variables (Vite).
# Copy to `.env` and adjust as needed. Only vars prefixed with VITE_ are exposed
# to the browser.

# Optional. Leave UNSET to use the Vite dev proxy (recommended for local dev):
# the frontend calls relative paths like /health and /api/... which Vite
# forwards to the backend on http://localhost:8000.
#
# Set this to call the backend directly (bypassing the proxy), e.g. for a
# deployed build:
# VITE_API_BASE_URL=http://localhost:8000
