# Backend environment variables. Copy to `.env` and adjust as needed.
# All are optional; the defaults below match local development.

# Path to the SQLite cache database.
# STOCKPULSE_DB_PATH=stockpulse.db

# Comma-separated list of allowed browser origins for CORS.
# Default is the Vite dev server.
# STOCKPULSE_CORS_ORIGINS=http://localhost:5173
