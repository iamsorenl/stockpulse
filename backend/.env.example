# Backend environment variables. Copy to `.env` and fill in as needed:
#   cp .env.example .env
# `.env` is gitignored — your keys never get committed.

# --- Core (M1); optional, defaults match local dev ---------------------------

# Path to the SQLite cache database.
# STOCKPULSE_DB_PATH=stockpulse.db

# Comma-separated allowed browser origins for CORS (default: Vite dev server).
# STOCKPULSE_CORS_ORIGINS=http://localhost:5173


# --- M2 sentiment: Reddit data (Arctic Shift, keyless) -----------------------
# Reddit disabled self-serve API keys (2025), so we read public Reddit data via
# Arctic Shift (https://arctic-shift.photon-reddit.com) — free, no key required.
# Leave this unset; only override to point at a mirror or for testing.
# ARCTIC_SHIFT_BASE_URL=https://arctic-shift.photon-reddit.com/api


# --- M2 sentiment: Groq LLM (free tier) --- THE ONLY KEY M2 NEEDS ------------
# Free API key: https://console.groq.com -> API Keys
GROQ_API_KEY=
# Optional model override (default: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant


# --- M2 sentiment: Ollama (optional, fully local, unlimited) ------------------
# Only needed if you want a local fallback instead of / in addition to Groq.
# Requires Ollama installed with the model pulled (e.g. `ollama pull llama3.1`).
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
